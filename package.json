  },
  "homepage": "https://cocreate.app/docs/server-side-render",
  "funding": {
    "type": "GitHub Sponsors ❤",
    "url": "https://github.com/sponsors/CoCreate-app"
  },
  "main": "./src/index.js",
  "dependencies": {
    "@cocreate/utils": "^1.39.0",
    "node-html-parser": "^6.1.12"
  }
}
